# Copy this file to .env and fill in your values for local development.
# Never commit .env to git — it contains secrets.

# PostgreSQL connection string
# Install PostgreSQL locally or use Docker: docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dailyaiartist

# OpenAI API key — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Any random string — used to sign session cookies
SESSION_SECRET=change-me-to-something-random

# Gelato API key — get yours at https://dashboard.gelato.com under Settings > API Access
GELATO_API_KEY=your-gelato-key-here

# Port (optional — defaults to 5000)
# PORT=5000
